{
    "name": "sd/symfony-invaders",
    "license": "MIT",
    "type": "project",
    "description": "Symfony Invaders",
    "require": {
        "php": ">=8.4.1",
        "ext-pcntl": "*",
        "symfony/console": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/stopwatch": "^8.1",
        "symfony/tui": "^8.1",
        "symfony/yaml": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    }
}
